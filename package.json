{
  "name": "rmapi-js",
  "version": "10.2.0",
  "description": "JavaScript implementation of the reMarkable 1.5 api",
  "repository": {
    "type": "git",
    "url": "git+ssh://git@github.com/erikbrinkman/rmapi-js.git"
  },
  "homepage": "https://erikbrinkman.github.io/rmapi-js/",
  "author": "Erik Brinkman <erik.brinkman@gmail.com>",
  "license": "MIT",
  "keywords": [
    "remarkable"
  ],
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "unpkg": "./dist/rmapi-js.esm.min.js",
  "engines": {
    "node": ">=22"
  },
  "files": [
    "./dist/**/*.js",
    "./dist/**/*.d.ts"
  ],
  "scripts": {
    "doc": "typedoc",
    "doc:md": "typedoc --options typedoc.md.json && node scripts/build-docs-md.js",
    "fmt": "biome format --write",
    "lint": "tsc && biome check && typedoc --emit none",
    "export": "tsc -p tsconfig.build.json && bun build src/index.ts --minify --outfile dist/rmapi-js.esm.min.js",
    "prepack": "bun lint && bun test --coverage && bun export"
  },
  "dependencies": {
    "crc-32": "^1.2.2",
    "jszip": "^3.10.1",
    "uuid": "^14.0.0",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.12",
    "@types/bun": "^1.3.12",
    "@types/uuid": "^11.0.0",
    "typedoc-plugin-markdown": "^4.11.0",
    "typedoc": "^0.28.19",
    "typescript": "~6.0.3"
  }
}
